# ───── Telegram ─────
BOT_TOKEN=123456:replace_me_with_real_token_from_BotFather
# Список Telegram ID админов через запятую. Эти юзеры видят /admin, /stats, /give.
ADMIN_IDS=123456789

# Публичный URL бота (HTTPS!) — используется для:
#   • вебхуков платёжек (YooKassa/OxaPay шлют сюда колбэки)
#   • агрегатора подписок (https://${PUBLIC_URL}/sub/<token>)
# В dev можно использовать ngrok/cloudflared.
PUBLIC_URL=https://bot.example.com

# Порт HTTP-сервера бота (вебхуки, /sub, /admin)
HTTP_PORT=8080

# ───── DB ─────
# Для старта SQLite одним файлом. Можно сменить на postgres:// в проде.
DATABASE_URL="file:./prisma/bot.db"

# ───── Панель (наивпанель / setpow) ─────
# Базовый URL панели (без слеша в конце)
PANEL_URL=https://panel.example.com
# Тот же PANEL_API_KEY, что задан в env панели. См. naivepanel/.env.
PANEL_API_KEY=replace_me_with_long_random_secret

# ───── Платежи ─────
# YooKassa (РФ-карты): shopId + secretKey из ЛК
YOOKASSA_SHOP_ID=
YOOKASSA_SECRET_KEY=

# Telegram Stars — токен провайдера НЕ нужен, оплата проходит через
# нативный sendInvoice с currency=XTR. Включается флагом.
TG_STARS_ENABLED=true

# OxaPay (крипта): merchant API key
OXAPAY_MERCHANT_KEY=

# Crypto Pay API token от @CryptoBot (Telegram-нативная крипто-оплата).
# Как получить:
#   1. Открой @CryptoBot → /pay → Crypto Pay → Create App
#   2. Скопируй токен формата "12345:AAxxxxxxxxx..."
#   3. Там же → Webhooks → Enable → URL = ${PUBLIC_URL}/webhook/cryptobot
# Поддерживает USDT, TON, BTC, ETH и др. — цены автоматически
# конвертируются из RUB в крипту в момент оплаты.
CRYPTOPAY_API_TOKEN=
# Если true — используется @CryptoTestnetBot (testnet-pay.crypt.bot).
# Только для разработки. На проде оставь false.
CRYPTOPAY_TESTNET=false

# ───── Реферальная программа ─────
# Дни, которые получает реферер за первую ПЛАТНУЮ покупку приглашённого.
REFERRAL_BONUS_DAYS=7

# ───── Триал ─────
TRIAL_DAYS=3

# ───── Веб-админка ─────
ADMIN_WEB_USER=admin
ADMIN_WEB_PASSWORD=change_me

# ───── Мини-апп: внешние ссылки ─────
# Контакт поддержки. Например: https://t.me/cryox_support
# Пусто → кнопка «Написать в поддержку» в мини-аппе скрывается.
SUPPORT_URL=
# Telegram-канал. Например: https://t.me/cryox_news
# Пусто → строка «Telegram-канал» в профиле скрывается.
CHANNEL_URL=

# ───── Логи ─────
LOG_LEVEL=info
NODE_ENV=development
